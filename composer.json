{
    "name": "gomdimapps/tools",
    "description": "A wrapper of utility tools (HTTP calls, IP lookup, etc.) for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "tools", "http", "ip", "wrapper"],
    "authors": [
        {
            "name": "GomdimApps",
            "email": "isac.gondim.dev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "GomdimApps\\Tools\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GomdimApps\\Tools\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GomdimApps\\Tools\\ToolsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
